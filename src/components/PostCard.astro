---
import TagList from "./TagList.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  publishDate: Date;
  tags?: string[];
  kind: "博客" | "方法";
}

const { href, title, description, publishDate, tags = [], kind } = Astro.props;
const dateLabel = publishDate.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="glass card post-card reveal hover-sheen">
  <div class="card-gloss" aria-hidden="true"></div>
  <div class="post-card-content">
    <div class="post-card-header">
      <span class="post-type">{kind}</span>
      <span class="date-label">{dateLabel}</span>
    </div>
    <h3><a href={href}>{title}</a></h3>
    <p>{description}</p>
    <TagList tags={tags} />
  </div>
  <div class="card-actions">
    <a class="button button-secondary" href={href}>继续阅读</a>
  </div>
</article>
