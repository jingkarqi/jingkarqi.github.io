---
import { getCollection } from "astro:content";
import Hero from "../components/Hero.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order || b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .filter((project) => project.data.featured);

const blogPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const methods = (await getCollection("methods"))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2);
---

<BaseLayout>
  <Hero />

  <section id="projects" class="container section homepage-section">
    <div class="reveal">
      <SectionTitle
        eyebrow="Projects"
        title="精选项目"
        description="先看代表项目，再决定要不要继续读方法和文章。这一层是首页最直接的能力证明。"
        linkHref="/projects"
        linkLabel="查看全部项目"
      />
    </div>
    <div class="card-grid featured-project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="container section homepage-section">
    <div class="latest-writing-shell">
      <div class="glass split-panel reveal">
        <div class="reveal active-on-loadless">
          <SectionTitle
            eyebrow="Methods"
            title="方法与思考"
            description="把项目里反复出现的判断标准和设计原则沉淀成长期有效的页面。"
            linkHref="/methods"
            linkLabel="查看方法页"
          />
        </div>
        <div class="post-grid split-post-grid">
          {
            methods.map((entry) => (
              <PostCard
                href={`/methods/${entry.id}/`}
                title={entry.data.title}
                description={entry.data.description}
                publishDate={entry.data.publishDate}
                tags={entry.data.tags}
                kind="方法"
              />
            ))
          }
        </div>
      </div>

      <div class="glass split-panel reveal">
        <div class="reveal active-on-loadless">
          <SectionTitle
            eyebrow="Writing"
            title="最近更新"
            description="博客主要记录项目复盘、AI 工具工作流以及具体实现中的工程判断。"
            linkHref="/blog"
            linkLabel="进入博客"
          />
        </div>
        <div class="post-grid split-post-grid">
          {
            blogPosts.map((entry) => (
              <PostCard
                href={`/blog/${entry.id}/`}
                title={entry.data.title}
                description={entry.data.description}
                publishDate={entry.data.publishDate}
                tags={entry.data.tags}
                kind="博客"
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="container section homepage-section">
    <div class="glass about-preview reveal">
      <div class="about-preview-copy">
        <p class="section-eyebrow">About</p>
        <h2>这不是项目清单页，而是一张持续更新的工作首页。</h2>
        <p>
          我更关心工具是否真的进入长期使用，而不是只做出能演示的功能。这个站点同时承载项目、博客和方法页，用来保留那些可以被复用的判断过程。
        </p>
      </div>
      <div class="about-preview-meta">
        <span class="hero-tag">项目</span>
        <span class="hero-tag">博客</span>
        <span class="hero-tag">方法页</span>
        <a class="button button-secondary" href="/about">查看完整关于</a>
      </div>
    </div>
  </section>

  <script is:inline>
    const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    const parallaxElements = document.querySelectorAll(".hero-parallax");

    if (parallaxElements.length > 0 && !motionQuery.matches) {
      const moveParallax = (event) => {
        const centerX = window.innerWidth / 2;
        const centerY = window.innerHeight / 2;
        const offsetX = (event.clientX - centerX) / centerX;
        const offsetY = (event.clientY - centerY) / centerY;

        parallaxElements.forEach((element) => {
          const depth = Number(element.dataset.depth || 10);
          element.style.transform =
            `translate3d(${offsetX * depth}px, ${offsetY * depth}px, 0)`;
        });
      };

      const resetParallax = () => {
        parallaxElements.forEach((element) => {
          element.style.transform = "translate3d(0, 0, 0)";
        });
      };

      document.addEventListener("mousemove", moveParallax);
      document.addEventListener("mouseleave", resetParallax);
    }
  </script>
</BaseLayout>
