---
import { getCollection, render } from "astro:content";
import TagList from "../../components/TagList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((entry) => !entry.data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateLabel = entry.data.publishDate.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="container detail-shell">
    <section class="detail-hero-shell">
      <div class="glass detail-intro reveal">
        <p class="eyebrow">Blog</p>
        <h1>{entry.data.title}</h1>
        <p class="lead">{entry.data.description}</p>
        <div class="detail-meta">
          <span class="pill">{dateLabel}</span>
        </div>
        <TagList tags={entry.data.tags} />
      </div>

      <aside class="glass meta-card reveal">
        <p class="meta-card-title">文章信息</p>
        <ul class="page-rail-list">
          <li class="page-rail-item">
            <strong>{dateLabel}</strong>
            <span>发布时间</span>
          </li>
          <li class="page-rail-item">
            <strong>{entry.data.tags.length} 个标签</strong>
            <span>用于和方法页、项目复盘建立主题连接</span>
          </li>
          <li class="page-rail-item">
            <strong>工程复盘</strong>
            <span>重点记录取舍、结构和长期维护判断</span>
          </li>
        </ul>
      </aside>
    </section>

    <section class="detail-body-grid">
      <div class="prose content-card reveal">
        <Content />
      </div>
      <aside class="glass sidebar-card meta-card reveal">
        <h3>这篇文章适合</h3>
        <ul class="simple-list">
          <li>想快速理解项目设计取舍的人。</li>
          <li>想把工具做成可长期维护产品的人。</li>
          <li>想看具体方法而不是抽象口号的人。</li>
        </ul>
      </aside>
    </section>
  </article>
</BaseLayout>
