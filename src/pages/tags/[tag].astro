---
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface TagEntry {
  href: string;
  title: string;
  description: string;
  publishDate: Date;
  tags: string[];
  kind: "博客" | "方法";
}

export async function getStaticPaths() {
  const { getCollection } = await import("astro:content");
  const tagMap = new Map<string, TagEntry[]>();

  const blogEntries = (await getCollection("blog")).filter((entry) => !entry.data.draft);
  const methodEntries = await getCollection("methods");

  for (const entry of blogEntries) {
    for (const tag of entry.data.tags) {
      const list = tagMap.get(tag) ?? [];
      list.push({
        href: `/blog/${entry.id}/`,
        title: entry.data.title,
        description: entry.data.description,
        publishDate: entry.data.publishDate,
        tags: entry.data.tags,
        kind: "博客",
      });
      tagMap.set(tag, list);
    }
  }

  for (const entry of methodEntries) {
    for (const tag of entry.data.tags) {
      const list = tagMap.get(tag) ?? [];
      list.push({
        href: `/methods/${entry.id}/`,
        title: entry.data.title,
        description: entry.data.description,
        publishDate: entry.data.publishDate,
        tags: entry.data.tags,
        kind: "方法",
      });
      tagMap.set(tag, list);
    }
  }

  return Array.from(tagMap.entries()).map(([tag, entries]) => ({
    params: { tag },
    props: {
      tag,
      entries: entries.sort((a, b) => b.publishDate.valueOf() - a.publishDate.valueOf()),
    },
  }));
}

const { tag, entries } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`和 ${tag} 相关的文章与方法页。`}>
  <section class="container list-shell">
    <div class="page-intro">
      <p class="eyebrow">Tag</p>
      <h1 class="page-title">#{tag}</h1>
      <p>和这个主题相关的内容集中在这里，便于按问题而不是按时间查找。</p>
    </div>
    <div class="post-grid">
      {
        entries.map((entry: TagEntry) => (
          <PostCard
            href={entry.href}
            title={entry.title}
            description={entry.description}
            publishDate={entry.publishDate}
            tags={entry.tags}
            kind={entry.kind}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
